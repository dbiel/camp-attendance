rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the request is from an authenticated admin
    function isAdmin() {
      return request.auth != null;
    }

    // Students: admin-only (all access goes through server-side API)
    match /students/{studentId} {
      allow read, write: if false; // Server-side only via Admin SDK
    }

    // Faculty: publicly readable (teacher landing page), admin writes
    match /faculty/{facultyId} {
      allow read: if true;
      allow write: if false; // Server-side only via Admin SDK
    }

    // Periods: publicly readable (cached client-side), no client writes
    match /periods/{periodId} {
      allow read: if true;
      allow write: if false;
    }

    // Sessions: publicly readable (schedule display), admin writes
    match /sessions/{sessionId} {
      allow read: if true;
      allow write: if false;
    }

    // Session Students: publicly readable (teacher attendance page, non-PII only)
    match /session_students/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Attendance: admin can read via client SDK (real-time listener)
    // All writes go through server-side API
    match /attendance/{docId} {
      allow read: if isAdmin();
      allow write: if false; // Server-side only via Admin SDK
    }

    // Config: publicly readable (camp code validated server-side)
    match /config/{docId} {
      allow read: if false; // Server-side only — camp code must not be exposed to client
      allow write: if false;
    }

    // Catch-all default deny. Any new collection added via the Admin SDK
    // is read/write-denied to clients until an explicit `match` block is
    // added above this line. Prevents "forgot to write a rule" footguns.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
