rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the request is from an authenticated admin
    function isAdmin() {
      return request.auth != null;
    }

    // Students: admin-only (all access goes through server-side API)
    match /students/{studentId} {
      allow read, write: if false; // Server-side only via Admin SDK
    }

    // Faculty: server-only. (Was world-readable for the dormant teacher landing;
    // the live admin app reads via Admin SDK. No live client SDK read exists.)
    match /faculty/{facultyId} {
      allow read, write: if false; // Server-side only via Admin SDK
    }

    // Periods: server-only. (Was world-readable; no live client SDK read.)
    match /periods/{periodId} {
      allow read, write: if false;
    }

    // Sessions: server-only. (Was world-readable; no live client SDK read.)
    match /sessions/{sessionId} {
      allow read, write: if false;
    }

    // Session Students: server-only. SECURITY: previously `read: if true`, which
    // exposed denormalized camper PII (first_name, last_initial, instrument,
    // dorm_room) for the whole roster to any anonymous client. Locked down.
    match /session_students/{docId} {
      allow read, write: if false;
    }

    // Attendance: server-only. (Was `read: if isAdmin()` for the dormant
    // dashboard/faculty-status/coverage client listeners, which are being
    // removed; `request.auth != null` paths must not expose this either.)
    match /attendance/{docId} {
      allow read, write: if false; // Server-side only via Admin SDK
    }

    // Config: publicly readable (camp code validated server-side)
    match /config/{docId} {
      allow read: if false; // Server-side only — camp code must not be exposed to client
      allow write: if false;
    }

    // Incident command center collections: server-side only via Admin SDK.
    // Share-link access (Phase 2) goes through token-validating API routes.
    match /cases/{caseId} {
      allow read, write: if false;
    }
    match /case_events/{eventId} {
      allow read, write: if false;
    }
    match /contacts/{contactId} {
      allow read, write: if false;
    }

    // iMessage ingest (Plan B): server-side only via Admin SDK. The `texts`
    // collection holds private inbound messages (super-admin-only, read via
    // GET /api/texts); `ingest_state` holds the watcher's delta cursor. No
    // client ever touches either.
    match /texts/{id} {
      allow read, write: if false;
    }
    match /ingest_state/{id} {
      allow read, write: if false;
    }

    // Catch-all default deny. Any new collection added via the Admin SDK
    // is read/write-denied to clients until an explicit `match` block is
    // added above this line. Prevents "forgot to write a rule" footguns.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
