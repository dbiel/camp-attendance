# iMessage watcher environment.
#
# The watcher loads the repo's .env.local automatically (it reuses the app's
# Firebase service account — no separate key). These vars are OPTIONAL
# overrides; copy to `.env` in this directory only if you need to change them.

# Path to the Messages database (defaults to ~/Library/Messages/chat.db).
# CHAT_DB_PATH=/Users/davidbiel/Library/Messages/chat.db

# Poll interval in milliseconds (default 15000).
# POLL_INTERVAL_MS=15000

# Firebase Admin creds — normally inherited from ../../.env.local:
# FB_PROJECT_ID=ttuboc-attendance
# FB_CLIENT_EMAIL=...
# FB_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
