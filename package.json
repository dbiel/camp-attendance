{
  "name": "ttu-band-orchestra-camp",
  "version": "1.0.0",
  "description": "Camp management and attendance tracking system for TTU Band and Orchestra Camp",
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run tests/unit/",
    "test:unit": "vitest run tests/unit/",
    "test:integration": "bash scripts/test-with-emulator.sh",
    "test:security": "bash scripts/test-with-emulator.sh tests/security/",
    "test:all": "npm run lint && npm run typecheck && npm run test:unit && npm run test:integration",
    "test:e2e": "playwright test",
    "test:watch": "vitest watch tests/unit/",
    "prepare": "husky"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "autoprefixer": "^10.4.16",
    "firebase": "^11.0.0",
    "firebase-admin": "^12.0.0",
    "next": "^14.0.0",
    "postcss": "^8.4.32",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@firebase/rules-unit-testing": "^5.0.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "dotenv": "^17.3.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.0"
  }
}
